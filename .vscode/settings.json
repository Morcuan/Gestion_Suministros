{
    // ===== ZOOM GENERAL =====
    "window.zoomLevel": 1.25,

    // ===== FORMATEADOR =====
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,

    // ===== BLACK =====
    "black-formatter.args": [
        "--line-length=88"
    ],

    // ===== RUFF (NUEVO LSP NATIVO) =====
    "ruff.enable": true,
    "ruff.lint.enable": true,
    "ruff.lint.select": ["E", "F", "W", "I"],
    "ruff.lint.ignore": ["E501"],
    "ruff.format.enable": false,
    "ruff.organizeImports": true,

    // ===== PYTHON / PYLANCE =====
    "python.analysis.typeCheckingMode": "basic",
    "python.linting.enabled": false,

    // Rutas adicionales para que Pylance encuentre PySide6
    "python.analysis.extraPaths": [
        "/usr/lib/python3/dist-packages",
        "/usr/lib/python3/dist-packages/PySide6"
    ],

    // ===== TERMINAL =====
    "terminal.integrated.fontSize": 14,

    // ===== CALIDAD DE VIDA =====
    "errorLens.enabled": true,
    "errorLens.fontWeight": "normal",
    "errorLens.fontStyleItalic": false,
    "errorLens.margin": "4px",

    // ===== ARCHIVOS =====
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,

    // ===== ESTÉTICA =====
    "workbench.iconTheme": "material-icon-theme",

    // ===== EDITOR =====
    "editor.fontSize": 14,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "editor.tabSize": 4,
    "editor.detectIndentation": false
}
